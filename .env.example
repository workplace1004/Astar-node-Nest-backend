# PostgreSQL (required for Prisma)
DATABASE_URL="postgresql://USER:123@localhost:5432/astar?schema=public"

# Optional
PORT=3000
JWT_SECRET=your-secret-change-in-production
# Misma cuenta que la clave pública del frontend (VITE_MERCADOPAGO_PUBLIC_KEY en el proyecto frontend).
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxx
# Firma de webhooks (Mercado Pago → Tu integración → Webhooks → “Clave secreta” / secret signature).
# URL del webhook: https://TU_BACKEND/payments/webhooks/mercadopago (eventos de payment)
# MERCADOPAGO_WEBHOOK_SECRET=
# PayPal (suscripción y carrito en USD) — sandbox por defecto si PAYPAL_MODE no es "live"
# En el frontend, la misma app: VITE_PAYPAL_CLIENT_ID (Smart Buttons sin redirección).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=live
# Webhook ID (PayPal Developer → app → Webhooks → crear webhook → URL https://TU_BACKEND/payments/webhooks/paypal → evento PAYMENT.CAPTURE.COMPLETED)
# PAYPAL_WEBHOOK_ID=
# Astrology API v3 — https://astrology-api.io (Bearer key, formato ask_...)
ASTROLOGY_API_KEY=your_api_key
# Opcional: por defecto https://api.astrology-api.io
# ASTROLOGY_API_BASE_URL=

# ExchangeRate-API (https://www.exchangerate-api.com/) — USD→ARS en portal / Servicios extras
EXCHANGE_RATE_API_KEY=
