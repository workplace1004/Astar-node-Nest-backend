generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  client
}

enum SubscriptionStatus {
  active
  inactive
  cancelled
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  passwordHash       String             @map("password_hash")
  role               UserRole           @default(client)
  isActive           Boolean            @default(true) @map("is_active")
  subscriptionStatus SubscriptionStatus @default(inactive) @map("subscription_status")
  birthDate          String?            @map("birth_date")
  birthPlace         String?            @map("birth_place")
  birthTime          String?            @map("birth_time")
  avatarUrl          String?            @map("avatar_url")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  reports            Report[]
  messages           Message[]
  notifications      Notification[]
  orders             Order[]
  questions          Question[]
  adminNotificationReads AdminNotificationRead[]
}

model AdminNotificationRead {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  notificationId String   @map("notification_id")
  readAt         DateTime @default(now()) @map("read_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@map("admin_notification_read")
}

model Report {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @map("type")
  title     String
  content   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
}

model Message {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   @map("type")
  content     String   @db.Text
  questionText String? @map("question_text") @db.Text
  monthLabel  String?  @map("month_label")
  createdAt   DateTime @default(now()) @map("created_at")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?  @db.Text
  category  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("draft")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model KnowledgeCategory {
  id       String             @id @default(cuid())
  title    String
  entries  KnowledgeEntry[]
  createdAt DateTime @default(now()) @map("created_at")
}

model KnowledgeEntry {
  id         String            @id @default(cuid())
  categoryId String           @map("category_id")
  category   KnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  content    String            @db.Text
  createdAt  DateTime         @default(now()) @map("created_at")
}

model Order {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  amount    String
  method    String
  createdAt DateTime @default(now()) @map("created_at")
}

enum QuestionStatus {
  new
  waiting
  answered
}

model Question {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question  String         @db.Text
  answer    String?        @db.Text
  status    QuestionStatus @default(new)
  createdAt DateTime       @default(now()) @map("created_at")
}

model Preview {
  id            String   @id @default(cuid())
  email         String
  birthDate     String   @map("birth_date")
  birthTime     String   @map("birth_time")
  birthPlace    String   @map("birth_place")
  sunSign       String   @map("sun_sign")
  moonSign      String   @map("moon_sign")
  ascendantSign String   @map("ascendant_sign")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("preview")
}
